# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info

# ─── PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://lilly:lilly_secret@localhost:5432/lilly_os
DB_POOL_MAX=20

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=lilly:

# ─── Agent / AI ───────────────────────────────────────
# Optional LLM endpoint for reasoning (OpenAI-compatible)
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_ENABLED=false

# ─── Brand / Business ─────────────────────────────────
CREATOR_HANDLE=lilly
BRAND_VOICE=confident, playful, professional
PRIMARY_TRAFFIC_URL=https://example.com/onlyfans
TIMEZONE=America/New_York

# ─── Publishing (platforms that allow scheduled posts) ─
# Set enabled platforms and credentials via secure secrets in production.
PUBLISH_AUTO_APPROVED=false
PUBLISH_REQUIRE_COMPLIANCE=true
DEFAULT_POST_INTERVAL_MINUTES=180

# ─── WebSocket ────────────────────────────────────────
WS_PATH=/ws

# ─── Autonomy (self-run) ──────────────────────────────
AUTONOMY_ENABLED=true
AUTONOMY_INTERVAL_MINUTES=60
AUTONOMY_LEVEL=full
AUTONOMY_GENERATE_MEDIA=true
AUTONOMY_DEFAULT_GOAL=Continuously grow traffic to the primary adult content account via compliant multi-platform posts and self-generated media
DAILY_IMAGE_BUDGET=50
DAILY_TOKEN_BUDGET=500000
FAN_AUTO_REPLY=false
FAN_IMAGE_PER_USER_DAY=3

# ─── Media / LoRA ─────────────────────────────────────
MEDIA_ENABLED=false
MEDIA_PROVIDER=stub
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev
LORA_TRIGGER=lillyissilly
LORA_PATH_OR_URL=
REPLICATE_API_TOKEN=

# ─── Persona ──────────────────────────────────────────
CREATOR_HANDLE=lillyissilly
PERSONA_BIO=Lilly is an adult content creator. She speaks in first person and drives interest to her primary page.

# ─── Training chat (2 people web UI at /chat) ─────────
CHAT_ENABLED=true
CHAT_PASSWORD=lilly-train-2026

# ─── Webhooks ─────────────────────────────────────────
WEBHOOK_SECRET=change-me-webhook-secret

# ─── Security ─────────────────────────────────────────
API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

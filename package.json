{
  "name": "lilly-os",
  "version": "1.0.0",
  "description": "Lilly OS — autonomous business assistant for adult content creators",
  "main": "server.cjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node server.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "dataset:prepare": "tsx scripts/prepare-dataset.ts",
    "dataset:status": "tsx scripts/dataset-status.ts",
    "start:prod": "node server.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "lilly-os",
    "agent",
    "creator-tools",
    "analytics"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "uuid": "^11.0.5",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
